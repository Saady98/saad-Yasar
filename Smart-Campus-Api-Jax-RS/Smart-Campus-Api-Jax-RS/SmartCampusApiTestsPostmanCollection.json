              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"value\": 22.1\n}"
            },
            "url": "http://localhost:8090/smart-campus-api/api/v1/sensors/TEMP-001/readings",
            "description": "Expected success; server auto-fills timestamp when omitted."
          }
        },
        {
          "name": "GET Fetch sensor history",
          "request": {
            "method": "GET",
            "url": "http://localhost:8090/smart-campus-api/api/v1/sensors/TEMP-001/readings"
          }
