                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"value\": 23.5,\n    \"timestamp\": 1698141600000\n}"
            },
            "url": "http://localhost:8090/smart-campus-api/api/v1/sensors/TEMP-001/readings",
            "description": "Server generates reading id automatically; timestamp is accepted when provided."
          }
        },
        {
          "name": "POST Append reading without timestamp (Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
